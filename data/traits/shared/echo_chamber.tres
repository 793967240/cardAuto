[gd_resource type="Resource" load_steps=3 format=3 uid="uid://trait_echo_chamber"]

[ext_resource type="Script" path="res://src/data_models/trait_data.gd" id="1_data"]
[ext_resource type="Script" path="res://src/core/effects/traits/trait_effect_echo.gd" id="2_fx"]

[sub_resource type="Resource" id="effect_1"]
script = ExtResource("2_fx")
max_triggers_per_chain = 999

[resource]
script = ExtResource("1_data")
id = &"echo_chamber"
display_name_key = "trait.echo_chamber.name"
desc_key = "trait.echo_chamber.desc"
scope = 1
trigger = 1
tags = [&"echo"]
mutex_tags = [&"echo"]
effect = SubResource("effect_1")
description_template = "该扩展底座所有卡打出时，额外触发前一张卡。"
