[internationalization]

locale/translations=PackedStringArray("res://translations/zh_CN.csv", "res://translations/en.csv")
locale/fallback="en"

[autoload]

GameState="*res://src/globals/game_state.gd"
Settings="*res://src/globals/settings.gd"
EventBus="*res://src/globals/event_bus.gd"
InputRouter="*res://src/input/input_router.gd"

[rendering]

