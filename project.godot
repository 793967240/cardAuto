; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters are generated from the editor's choices
; and they may not be used in the same way in the engine.
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TimeChain"
config/version="0.1.0"
config/description="时序录 - 时间轴卡牌构筑 Roguelike"
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=0
window/size/initial_position_type=2
window/size/resizable=true
window/handheld/orientation="landscape"
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="fractional"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[input]

pause_toggle={
"deadzone": 0.5,
